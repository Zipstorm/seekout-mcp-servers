# Server
SPOT_ENV=local
MCP_PORT=8001

# SeekOut Runtime API
SEEKOUT_RUNTIME_API_ENDPOINT=https://runtime-dev.seekout.io
SEEKOUT_RUNTIME_API_KEY={found in Azure Key Vault - ask team for access}

# Auth — JWT
SEEKOUT_JWKS_URI=https://recruit-api-app-dev.azurewebsites.net/api/oauth/jwks
SEEKOUT_OAUTH_ISSUER=https://recruit-api-app-dev.azurewebsites.net
SEEKOUT_MCP_AUDIENCE=seekout-mcp-server
SEEKOUT_MCP_RESOURCE_URL=http://localhost:8001/mcp

# Auth — API key for internal agents
MCP_INTERNAL_API_KEY=dev-internal-key-123

# Redis (session store)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# Query Store (for generating SeekOut app links)
# QUERY_STORE_ENDPOINT=https://recruit-querystore-func-prod.azurewebsites.net/api/StoreQuery
# QUERY_STORE_API_KEY=your-query-store-api-key

# Server
SPOT_ENV=local
MCP_PORT=8001

# SeekOut Runtime API
SEEKOUT_RUNTIME_API_ENDPOINT=https://your-runtime-api-url
SEEKOUT_RUNTIME_API_KEY=your-runtime-api-key

# Auth — JWT (not needed for local dev)
# SEEKOUT_JWKS_URI=https://app.seekout.io/api/oauth/jwks
# SEEKOUT_OAUTH_ISSUER=https://app.seekout.io
# SEEKOUT_MCP_AUDIENCE=seekout-mcp-server
# SEEKOUT_MCP_RESOURCE_URL=https://mcp.seekout.io/mcp

# Auth — API key for internal agents (not needed for local dev)
# MCP_INTERNAL_API_KEY=your-internal-api-key

# Redis (session store)
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600

# Query Store (for generating SeekOut app links)
# QUERY_STORE_ENDPOINT=https://recruit-querystore-func-prod.azurewebsites.net/api/StoreQuery
# QUERY_STORE_API_KEY=your-query-store-api-key
